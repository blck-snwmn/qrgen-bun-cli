{
  "name": "qrgen-bun-cli",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run index.ts",
    "build": "bun run build:macos && bun run build:linux",
    "build:macos": "bun build --compile --target=bun-darwin-arm64 ./index.ts --outfile=dist/qrgen-macos",
    "build:linux": "bun build --compile --target=bun-linux-x64 ./index.ts --outfile=dist/qrgen-linux",
    "test": "bun test",
    "lint": "oxlint --deny-warnings src index.ts",
    "lint:fix": "oxlint --deny-warnings src index.ts --fix",
    "fmt": "oxfmt --write src/ index.ts",
    "fmt:check": "oxfmt --check src/ index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "1.5.6",
    "bun-types": "1.3.14",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0"
  },
  "peerDependencies": {
    "typescript": "^5 || ^6.0.0 || ^7.0.0"
  },
  "dependencies": {
    "meow": "^14.0.0",
    "qrcode": "^1.5.4"
  }
}
